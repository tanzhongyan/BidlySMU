# Local DB connection details
DB_HOST=localhost
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=changeme
DB_PORT=5433

# Google gemini 2.5 flash
GEMINI_API_KEY=<REPLACE WITH KEY FROM AI STUDIO>

# SMU BOSS Automated Login Credentials
# For automated login with TOTP-based MFA (optional - can also pass to perform_automated_login())
BOSS_EMAIL=<REPLACE WITH SCHOOL EMAIL>
BOSS_PASSWORD=<REPLACE WITH SCHOOL PASSWORD>
# MFA Secret: Base32 encoded secret from Microsoft Authenticator app setup
# To get this: Go to Microsoft Authenticator > SMU account > Set up > "Can't scan?" > copy the secret key
BOSS_MFA_SECRET=<REPLACE WITH MFA SECRET>

# Academic Term ID in BOSS format (e.g., AY202526T3A = AY 2025/26, Term 3A)
ACAD_TERM_ID=AY202526T3A

# Path to bidding schedules JSON file
BIDDING_SCHEDULES_PATH=script_input/bidding_schedules.json